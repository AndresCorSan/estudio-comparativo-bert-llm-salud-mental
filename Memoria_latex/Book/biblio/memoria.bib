	langid = {english},
	file = {Full Text PDF:C\:\\Users\\andre\\Zotero\\storage\\4M75DCHG\\Morgan et al. - 1999 - The SCOFF questionnaire assessment of a new screening tool for eating disorders.pdf:application/pdf},
}

